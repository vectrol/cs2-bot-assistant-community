{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CS2人机助手社区版",
  "mainBinaryName": "CS2BotAssistantCE",
  "version": "1.3.1",
  "identifier": "com.aipc.cs2botassistantce",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CS2人机助手社区版",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "decorations": false,
        "shadow": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "resources": [
      "resources/CS2BotImprover.zip",
      "../LICENSE",
      "../NOTICE.md"
    ],
    "license": "AGPL-3.0-or-later",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
